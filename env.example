# Parliament IT Inventory - Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env itself.

# Django
SECRET_KEY=change-me-to-a-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
POSTGRES_DB=parliament_inventory
POSTGRES_USER=parliament
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# PRP API (External holder sync)
PRP_API_BASE_URL=https://prp.parliament.gov.bd
PRP_API_USERNAME=alamin
PRP_API_PASSWORD=Al@min91

# Redis (Celery broker)
REDIS_URL=redis://redis:6379/0
