# Parliament IT Inventory — Environment Variables
# Copy to .env and fill in real values before deploying.

# ── Django ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets-token-urlsafe-50
DEBUG=False
ALLOWED_HOSTS=inventory.parliament.gov.bd,localhost,127.0.0.1

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=parliament_inventory
POSTGRES_USER=parliament
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── PRP API (leave blank to skip sync) ─────────────────────────────────────
PRP_API_BASE_URL=https://prp.parliament.gov.bd
PRP_API_USERNAME=alamin
PRP_API_PASSWORD=Al@min91

# ── Post-deploy steps ───────────────────────────────────────────────────────
# 1. docker compose exec web python manage.py createsuperuser
# 2. docker compose exec web python manage.py create_groups
#    (also runs automatically on each container start)
# 3. Assign users to groups via Django admin: /admin/auth/group/
#    Groups: Admin | IT Officer | Viewer
#
# ── SSL (production) ────────────────────────────────────────────────────────
# Place signed certs at /etc/ssl/certs/parliament.crt and parliament.key
# For a self-signed dev cert:
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout nginx/ssl/parliament.key \
#     -out nginx/ssl/parliament.crt -subj "/CN=localhost"
# Then uncomment the ssl volume mount in docker-compose.yml
