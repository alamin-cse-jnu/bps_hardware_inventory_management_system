# Copy this file to .env and fill in the values before running docker compose.

# ── Django ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-python-secrets-token-urlsafe-50
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=parliament_inventory
POSTGRES_USER=parliament
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── PRP API (leave blank to skip sync) ─────────────────────────────────────
PRP_API_BASE_URL=https://prp.parliament.gov.bd
PRP_API_USERNAME=
PRP_API_PASSWORD=
